FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV UV_LINK_MODE=copy
ENV UV_PROJECT_ENVIRONMENT=/opt/finflow-venv
ENV PATH="/opt/finflow-venv/bin:/root/.local/bin:${PATH}"

RUN pip install --no-cache-dir uv

WORKDIR /app

COPY . .

RUN uv sync --extra dev

CMD ["sh", "-c", "uv sync --extra dev && uv run alembic upgrade head && uv run python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"]
